---
import { ClientRouter, fade } from "astro:transitions";
import "../styles/global.css";
import { withBase } from "../lib/urls";

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const {
  title,
  description = "UNLV ECON 495 Journal - undergraduate capstone research published as working papers.",
  bodyClass = "",
} = Astro.props;

const pathname = Astro.url.pathname;
const currentYear = new Date().getFullYear();
const navItems = [
  { href: withBase("/"), label: "Home" },
  { href: withBase("/issues/"), label: "Issues" },
  { href: withBase("/categories/"), label: "Categories" },
  { href: withBase("/our/"), label: "Research Pathway" },
  { href: withBase("/about/"), label: "About" },
  { href: withBase("/contact/"), label: "Contact" },
];

function normalize(path: string): string {
  return path.endsWith("/") ? path : `${path}/`;
}

function isActive(href: string): boolean {
  const current = normalize(pathname);
  const target = normalize(href);
  if (target === normalize(withBase("/"))) {
    return current === target;
  }
  return current.startsWith(target);
}
---

<!doctype html>
<html lang="en" transition:name="root" transition:animate="none">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <ClientRouter />
  </head>
  <body class={bodyClass || undefined}>
    <a class="skip-link" href="#content">Skip to content</a>

    <header class="site-header modern-header">
      <div class="site-shell site-topbar">
        <a class="site-title site-logo" href={withBase("/")}>UNLV ECON 495 Journal</a>

        <nav class="main-nav" aria-label="Primary">
          <ul>
            {navItems.map((item) => (
              <li>
                <a href={item.href} class={isActive(item.href) ? "is-active" : undefined}>{item.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main id="content" class="page-body" transition:name="page-main" transition:animate={fade()}>
      <div class="page-content">
        <slot />
      </div>
    </main>

    <footer class="site-footer modern-footer">
      <div class="site-shell footer-shell">
        <div class="footer-main" role="navigation" aria-label="Footer navigation">
          <section class="footer-brand">
            <h2 class="footer-journal">UNLV ECON 495 Journal</h2>
            <p class="footer-description">
              Open-access undergraduate working paper archive from ECON 495 at the University of Nevada, Las Vegas.
            </p>
          </section>

          <nav class="footer-nav" aria-label="Explore">
            <h3 class="footer-heading">Explore</h3>
            <ul class="footer-links">
              <li><a href={withBase("/")}>Home</a></li>
              <li><a href={withBase("/issues/")}>Issues</a></li>
              <li><a href={withBase("/categories/")}>Categories</a></li>
              <li><a href={withBase("/our/")}>Research Pathway</a></li>
              <li><a href={withBase("/about/")}>About</a></li>
              <li><a href={withBase("/contact/")}>Contact</a></li>
            </ul>
          </nav>

          <nav class="footer-nav" aria-label="Academic links">
            <h3 class="footer-heading">Academic Links</h3>
            <ul class="footer-links">
              <li><a href="https://www.unlv.edu/business" target="_blank" rel="noopener noreferrer">Lee Business School</a></li>
              <li><a href="https://www.unlv.edu/economics" target="_blank" rel="noopener noreferrer">Department of Economics</a></li>
              <li><a href="https://www.unlv.edu/our" target="_blank" rel="noopener noreferrer">Office of Undergraduate Research</a></li>
            </ul>
          </nav>
        </div>

        <div class="footer-utility">
          <p class="footer-utility-text">
            <span>&copy; <span data-current-year>{currentYear}</span> UNLV ECON 495 Journal.</span>
            <span class="footer-disclaimer">Working papers are student-authored and may be revised over time.</span>
          </p>

          <ul class="footer-utility-links">
            <li><a href={withBase("/policies/privacy/")}>Privacy</a></li>
            <li><a href={withBase("/policies/permissions/")}>Permissions</a></li>
            <li><a href={withBase("/policies/takedown/")}>Takedown</a></li>
          </ul>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const setCurrentYear = () => {
          const year = String(new Date().getFullYear());
          document.querySelectorAll("[data-current-year]").forEach((node) => {
            node.textContent = year;
          });
        };

        const collectRevealTargets = () => {
          const selectors = [
            "[data-reveal]",
            "main .content-section",
            "main .hero-panel",
            "main .card",
            "main .contact-card",
            "main .ga-card",
            "main .our-surface",
          ];

          const unique = new Set();
          selectors.forEach((selector) => {
            document.querySelectorAll(selector).forEach((node) => unique.add(node));
          });

          return Array.from(unique);
        };

        const initReveal = () => {
          const nodes = collectRevealTargets();
          if (nodes.length === 0) {
            return;
          }

          const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          if (reducedMotion || !("IntersectionObserver" in window)) {
            nodes.forEach((node) => node.classList.add("is-revealed"));
            return;
          }

          const observer = new IntersectionObserver(
            (entries, io) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-revealed");
                  io.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.12 }
          );

          nodes.forEach((node, index) => {
            if (!node.hasAttribute("data-reveal")) {
              node.setAttribute("data-reveal", "auto");
            }

            if (!node.hasAttribute("data-reveal-delay")) {
              node.setAttribute("data-reveal-delay", String(index % 3));
            }

            const bounds = node.getBoundingClientRect();
            if (bounds.top <= window.innerHeight * 0.92) {
              node.classList.add("is-revealed");
            } else {
              observer.observe(node);
            }
          });
        };

        const initCopyButtons = () => {
          const buttons = Array.from(document.querySelectorAll("[data-copy-target]"));
          if (buttons.length === 0) {
            return;
          }

          buttons.forEach((button) => {
            if (button.dataset.copyInit === "true") {
              return;
            }
            button.dataset.copyInit = "true";

            const originalLabel = (button.textContent || "Copy").trim();

            button.addEventListener("click", async () => {
              const selector = button.dataset.copyTarget || "";
              const target = selector ? document.querySelector(selector) : null;
              const text = (target?.textContent || "").trim();
              if (!text) {
                return;
              }

              const showCopied = () => {
                button.classList.add("is-copied");
                button.textContent = "Copied!";
                window.setTimeout(() => {
                  button.classList.remove("is-copied");
                  button.textContent = originalLabel;
                }, 1600);
              };

              try {
                await navigator.clipboard.writeText(text);
                showCopied();
                return;
              } catch (_) {
                const ta = document.createElement("textarea");
                ta.value = text;
                ta.setAttribute("readonly", "");
                ta.style.position = "fixed";
                ta.style.left = "-9999px";
                document.body.appendChild(ta);
                ta.select();
                try {
                  document.execCommand("copy");
                } catch (e) {
                  // noop
                }
                ta.remove();
                showCopied();
              }
            });
          });
        };

        const runEnhancements = () => {
          document.documentElement.classList.add("motion-ready");
          setCurrentYear();
          initReveal();
          initCopyButtons();
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", runEnhancements, { once: true });
        } else {
          runEnhancements();
        }

        document.addEventListener("astro:page-load", runEnhancements);
      })();
    </script>
  </body>
</html>
