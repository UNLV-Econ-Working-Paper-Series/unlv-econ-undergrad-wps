---
import PageBanner from "../components/PageBanner.astro";
import RichTextInline from "../components/RichTextInline.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { ABOUT_PAGE_CONTENT } from "../data/about-content";
import { PUBLIC_PROFILES } from "../data/public-profiles";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/urls";

const sortedProfiles = [...PUBLIC_PROFILES].sort(
  (a, b) => (a.sortOrder ?? Number.MAX_SAFE_INTEGER) - (b.sortOrder ?? Number.MAX_SAFE_INTEGER) || a.name.localeCompare(b.name)
);
const editorialTeam = sortedProfiles.filter((profile) => profile.sections.includes("editorial_team"));
const currentGraduateAssistants = sortedProfiles.filter(
  (profile) => profile.sections.includes("graduate_assistants") && profile.current !== false
);
---

<BaseLayout title="About | UNLV Undergraduate Economics Working Paper Series" bodyClass="section-about page-about page-about-modern">
  <PageBanner
    title={ABOUT_PAGE_CONTENT.banner.title}
    lead={ABOUT_PAGE_CONTENT.banner.lead}
    note={ABOUT_PAGE_CONTENT.banner.note}
  />

  <section class="content-section">
    <div class="page-with-toc">
      <aside class="page-with-toc__toc">
        <TableOfContents items={ABOUT_PAGE_CONTENT.tocItems} />
      </aside>

      <div class="page-with-toc__main">
        <section class="about-modern-shell">
          <section class="about-block about-card" aria-labelledby="about-glance-title">
            <h2 id="about-glance-title">{ABOUT_PAGE_CONTENT.atAGlance.title}</h2>
            <ul class="about-glance-list">
              {ABOUT_PAGE_CONTENT.atAGlance.items.map((item) => (
                <li><RichTextInline segments={item} /></li>
              ))}
            </ul>
          </section>

          <section class="about-block about-card" aria-labelledby="about-series-scope">
            <h2 id="about-series-scope">{ABOUT_PAGE_CONTENT.seriesScope.title}</h2>
            {ABOUT_PAGE_CONTENT.seriesScope.blocks.map((block) =>
              block.type === "paragraph" ? (
                <p><RichTextInline segments={block.segments} /></p>
              ) : block.type === "heading" ? (
                <h3>{block.text}</h3>
              ) : (
                <pre class="about-code"><code>{block.code}</code></pre>
              )
            )}
          </section>

          <section class="about-block about-card" aria-labelledby="about-process-title">
            <h2 id="about-process-title">{ABOUT_PAGE_CONTENT.publication.title}</h2>
            <ol class="about-stepper">
              {ABOUT_PAGE_CONTENT.publication.steps.map((step, index) => (
                <li class="about-step-card">
                  <span class="about-step-number">{index + 1}</span>
                  <h3>{step.title}</h3>
                  <p>{step.description}</p>
                </li>
              ))}
            </ol>
          </section>

          <section class="about-block about-card" aria-labelledby="about-policies-title">
            <h2 id="about-policies-title">{ABOUT_PAGE_CONTENT.policies.title}</h2>

            {ABOUT_PAGE_CONTENT.policies.sections.map((section) => (
              <details class="about-policy" open={section.open}>
                <summary>{section.summary}</summary>
                <div class="about-policy-body">
                  {section.blocks.map((block) =>
                    block.type === "paragraph" ? (
                      <p><RichTextInline segments={block.segments} /></p>
                    ) : block.type === "heading" ? (
                      <h3>{block.text}</h3>
                    ) : (
                      <pre class="about-code"><code>{block.code}</code></pre>
                    )
                  )}
                </div>
              </details>
            ))}
          </section>

          <section class="about-block about-card" aria-labelledby="about-team-title">
            <h2 id="about-team-title">{ABOUT_PAGE_CONTENT.editorialTeam.title}</h2>

            {editorialTeam.length === 0 ? (
              <p class="about-empty">No editorial team members are listed.</p>
            ) : (
              <div class="about-team-grid about-team-grid--editorial">
                {editorialTeam.map((person) => (
                  <article class="about-person-card">
                    {person.headshot ? (
                      <img class="about-person-thumb" src={withBase(person.headshot)} alt={person.name} />
                    ) : null}
                    <div>
                      <p class="about-role">{person.displayRole}</p>
                      <h3>{person.name}</h3>
                      <p>{person.summary}</p>
                    </div>
                  </article>
                ))}
              </div>
            )}
          </section>

          <section class="about-block about-card" aria-labelledby="about-credits-title">
            <h2 id="about-credits-title">{ABOUT_PAGE_CONTENT.credits.title}</h2>
            <ul class="about-glance-list">
              {ABOUT_PAGE_CONTENT.credits.items.map((item) => (
                <li>
                  <strong>{item.label}:</strong> {item.value}
                </li>
              ))}
            </ul>
          </section>

          <section class="about-block about-card" aria-labelledby="about-ga-title">
            <header class="about-section-head">
              <h2 id="about-ga-title">{ABOUT_PAGE_CONTENT.graduateAssistants.title}</h2>
              <a class="about-inline-link" href={withBase(ABOUT_PAGE_CONTENT.graduateAssistants.linkHref)}>
                {ABOUT_PAGE_CONTENT.graduateAssistants.linkLabel}
              </a>
            </header>

            {currentGraduateAssistants.length === 0 ? (
              <p class="about-empty">{ABOUT_PAGE_CONTENT.graduateAssistants.emptyText}</p>
            ) : (
              <div class="about-team-grid about-team-grid--ga">
                {currentGraduateAssistants.map((assistant) => (
                  <article class="about-person-card">
                    {assistant.headshot ? (
                      <img class="about-person-thumb" src={withBase(assistant.headshot)} alt={assistant.name} />
                    ) : null}
                    <div>
                      <p class="about-role">{assistant.displayRole}</p>
                      <h3>
                        {assistant.profileHref ? (
                          <a class="about-person-link" href={withBase(assistant.profileHref)}>{assistant.name}</a>
                        ) : (
                          assistant.name
                        )}
                      </h3>
                      <p>{assistant.summary}</p>
                    </div>
                  </article>
                ))}
              </div>
            )}
          </section>

          <section class="about-block about-card about-cta" aria-labelledby="about-cta-title">
            <h2 id="about-cta-title">{ABOUT_PAGE_CONTENT.cta.title}</h2>
            <p>{ABOUT_PAGE_CONTENT.cta.body}</p>
            <div class="page-intro-actions">
              {ABOUT_PAGE_CONTENT.cta.actions.map((action) => (
                <a class:list={["btn", "btn-small", action.primary ? "btn-primary" : null]} href={withBase(action.href)}>
                  {action.label}
                </a>
              ))}
            </div>
          </section>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
