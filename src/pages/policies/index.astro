---
import PageBanner from "../../components/PageBanner.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/urls";

const policies = [
  {
    slug: "focus-scope",
    title: "Focus & Scope",
    summary: "What belongs in the Series, what does not, and the working-paper notice.",
  },
  {
    slug: "open-access",
    title: "Open Access Policy",
    summary: "Free public access for readers; no author fees.",
  },
  {
    slug: "editorial-process",
    title: "Editorial Screening Process (Not Peer Review)",
    summary: "What the editorial check covers before a paper is posted.",
  },
  {
    slug: "permissions",
    title: "Copyright, Licensing & Permissions",
    summary: "Who owns the paper, what the Series may host, and how reuse works.",
  },
  {
    slug: "privacy",
    title: "Privacy Statement",
    summary: "What the site collects and how contact messages are handled.",
  },
  {
    slug: "corrections-versioning",
    title: "Corrections, Updates & Versioning",
    summary: "How updates, revisions, and stable links are handled.",
  },
  {
    slug: "ethics",
    title: "Publication Ethics & Integrity",
    summary: "Rules on plagiarism, data, disclosure, and corrections.",
  },
  {
    slug: "takedown",
    title: "Takedown / Rights & Privacy Requests",
    summary: "When a removal request may be made and how it is handled.",
  },
  {
    slug: "archiving",
    title: "Archiving & Preservation",
    summary: "How the site keeps pages available and records updates or withdrawals.",
  },
  {
    slug: "accessibility",
    title: "Accessibility",
    summary: "How to request accessible formats or help using a paper.",
  },
  {
    slug: "author-agreement",
    title: "Author Posting Agreement (Summary)",
    summary: "Plain-language summary of what authors allow when a paper is posted.",
  },
];
---

<BaseLayout
  title="Policies | UNLV Undergraduate Economics Working Paper Series"
  description="Policies for posting, rights, privacy, corrections, and access in the UNLV Undergraduate Economics Working Paper Series."
  bodyClass="page-policy-index"
>
  <PageBanner
    title="Policies"
    lead="Policies for posting papers, reader access, rights, corrections, and accessibility."
    compact
  />

  <section class="content-section policy-shell">
    <article class="policy-article">
      <h2>Policy Directory</h2>
      <p>
        Browse the Series policies on scope, access, rights, privacy, corrections, and archiving.
      </p>

      <div class="policy-directory" role="list" aria-label="Policy pages">
        {policies.map((policy) => (
          <a role="listitem" class="policy-directory-item" data-motion="gsap" href={withBase(`/policies/${policy.slug}/`)}>
            <h3>{policy.title}</h3>
            <p>{policy.summary}</p>
          </a>
        ))}
      </div>
    </article>
  </section>
</BaseLayout>
