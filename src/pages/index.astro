---
import BaseLayout from "../layouts/BaseLayout.astro";
import { HOMEPAGE_EDITABLE_CONTENT } from "../data/homepage-content";
import { NEWS_EVENTS } from "../data/news";
import { cleanPaperTitle, getCategoryGroups, getIssueGroups, paperHref } from "../lib/papers";
import { withBase } from "../lib/urls";

const issues = await getIssueGroups();
const categories = await getCategoryGroups();
const publishedIssues = issues.filter((issue) => issue.papers.length > 0);

const latestIssue = issues[0] ?? null;
const latestIssueTitles = (latestIssue?.papers ?? []).slice(0, 3);
const categoryChips = categories.filter((group) => group.count > 0).sort((a, b) => b.count - a.count).slice(0, 10);
const hasPublishedPapers = publishedIssues.length > 0;

const heroImage = withBase("/assets/images/lee-business-school.jpg");

const toDisplayHref = (href: string | undefined, fallback: string): string => {
  const candidate = (href ?? "").trim();
  const target = candidate.length > 0 ? candidate : fallback;
  if (!target) {
    return "";
  }
  if (/^(https?:)?\/\//.test(target) || target.startsWith("mailto:") || target.startsWith("#")) {
    return target;
  }

  const basePath = import.meta.env.BASE_URL || "/";
  if (basePath !== "/" && target.startsWith(basePath)) {
    return target;
  }
  return withBase(target);
};

const latestIssueEditable = HOMEPAGE_EDITABLE_CONTENT.latestIssue ?? {};
const newsAndEventsEditable = HOMEPAGE_EDITABLE_CONTENT.newsAndEvents ?? {};

const editableFeaturedItems = (latestIssueEditable.featuredItems ?? [])
  .map((item) => {
    const label = item.label?.trim() ?? "";
    const href = item.href?.trim() ?? "";
    return {
      label,
      href: href.length > 0 ? toDisplayHref(href, href) : "",
    };
  })
  .filter((item) => item.label.length > 0);

const featuredItems =
  editableFeaturedItems.length > 0
    ? editableFeaturedItems
    : latestIssueTitles.map((paper) => ({
        label: cleanPaperTitle(paper.data.title),
        href: paperHref(paper),
      }));

const defaultLatestIssueHref = latestIssue ? `/issues/${latestIssue.slug}/` : "/issues/";
const latestIssueTitle = latestIssueEditable.title?.trim() || latestIssue?.label || "Latest Issue";
const latestIssueHref = toDisplayHref(latestIssueEditable.href, defaultLatestIssueHref);
const latestIssueMeta = latestIssueEditable.metaText?.trim() || (latestIssue ? `${latestIssue.papers.length} papers` : "");
const latestIssueEmptyStateText = latestIssueEditable.emptyStateText?.trim() || "No papers posted in this issue yet";

const latestIssuePrimaryCta = {
  label: latestIssueEditable.primaryCta?.label?.trim() || "Browse Issue",
  href: toDisplayHref(latestIssueEditable.primaryCta?.href, defaultLatestIssueHref),
};

const defaultSecondaryCtaHref = latestIssueTitles[0] ? paperHref(latestIssueTitles[0]) : "";
const hasSecondaryCtaOverride = Boolean(
  latestIssueEditable.secondaryCta?.label?.trim() || latestIssueEditable.secondaryCta?.href?.trim()
);
const latestIssueSecondaryCta = hasSecondaryCtaOverride
  ? {
      label: latestIssueEditable.secondaryCta?.label?.trim() || "Read Featured Paper",
      href: toDisplayHref(latestIssueEditable.secondaryCta?.href, defaultSecondaryCtaHref || "/issues/"),
    }
  : defaultSecondaryCtaHref
    ? { label: "Read Featured Paper", href: defaultSecondaryCtaHref }
    : null;

const hasLatestIssueOverride = Boolean(
  latestIssueEditable.title?.trim() ||
    latestIssueEditable.href?.trim() ||
    latestIssueEditable.metaText?.trim() ||
    latestIssueEditable.emptyStateText?.trim() ||
    latestIssueEditable.primaryCta?.label?.trim() ||
    latestIssueEditable.primaryCta?.href?.trim() ||
    latestIssueEditable.secondaryCta?.label?.trim() ||
    latestIssueEditable.secondaryCta?.href?.trim() ||
    editableFeaturedItems.length > 0
);

const showLatestIssueCard = Boolean(latestIssue || hasLatestIssueOverride);

const newsEyebrow = newsAndEventsEditable.eyebrow?.trim() || "Updates";
const newsHeading = newsAndEventsEditable.title?.trim() || "News and Events";
const newsItems = ((newsAndEventsEditable.items ?? []).length > 0 ? newsAndEventsEditable.items ?? [] : NEWS_EVENTS)
  .map((item) => item.trim())
  .filter((item) => item.length > 0);
const newsEmptyStateText = newsAndEventsEditable.emptyStateText?.trim() || "News and event updates will be posted here";
---

<BaseLayout title="UNLV Undergraduate Economics Working Paper Series" bodyClass="page-home">
  <section
    class="hero-banner home-hero home-hero--modern full-bleed"
    style={`--hero-image: url('${heroImage}'); --hero-focus-x: 58%; --hero-focus-y: 10%; --hero-panel-top: clamp(10px, 2vh, 25px); --hero-panel-width: 1440px;`}
  >
    <div class="hero-content home-hero-content">
      <div class="hero-panel-shell">
        <div class="hero-panel">
          <p class="hero-kicker">UNLV Department of Economics</p>
          <h1>
            <span class="hero-title-line">UNLV Undergraduate Economics</span>
            <span class="hero-title-line">Working Paper Series</span>
          </h1>
          <p class="hero-subtitle">
            <span class="hero-subtitle-line">Archive for undergraduate economics working papers at UNLV</span>
            <span class="hero-subtitle-line">Published by semester issue</span>
          </p>
          <div class="hero-actions">
            <a class="btn btn-home-primary" href={withBase("/issues/")}>Browse Issues</a>
            <a class="btn btn-home-secondary" href={withBase(hasPublishedPapers ? "/papers/" : "/issues/archive/")}>
              {hasPublishedPapers ? "Search Papers" : "Browse Archive"}
            </a>
          </div>
        </div>
      </div>
    </div>

    <p class="hero-credit">
      Photo credit:
      <a
        href="https://www.unlv.edu/news/release/lee-business-school-maintains-accreditation-business-and-accounting-programs"
        target="_blank"
        rel="noopener noreferrer"
      >
        UNLV News (Lee Business School)
      </a>
    </p>
  </section>

  <section class="section home-section" aria-labelledby="latest-issue-title">
    <div class="section-head home-section-head">
      <div>
        <p class="eyebrow">Latest Issue</p>
        <h2 id="latest-issue-title">Latest Semester Release</h2>
      </div>
      <a class="link-inline" href={withBase("/issues/")}>View all issues</a>
    </div>

    {showLatestIssueCard ? (
      <article class="card home-surface home-latest-card" data-motion="gsap">
        <header class="home-latest-head">
          <h3><a href={latestIssueHref}>{latestIssueTitle}</a></h3>
          {latestIssueMeta ? <p class="home-issue-meta">{latestIssueMeta}</p> : null}
        </header>

        <ol class="home-featured-list">
          {featuredItems.length > 0 ? (
            featuredItems.map((item) => (
              <li>
                {item.href ? <a href={item.href}>{item.label}</a> : item.label}
              </li>
            ))
          ) : (
            <li class="muted">{latestIssueEmptyStateText}</li>
          )}
        </ol>

        <div class="card-actions">
          {latestIssuePrimaryCta.label ? (
            <a class="btn btn-home-primary" href={latestIssuePrimaryCta.href}>
              {latestIssuePrimaryCta.label}
            </a>
          ) : null}
          {latestIssueSecondaryCta?.label ? (
            <a class="btn btn-home-secondary" href={latestIssueSecondaryCta.href}>
              {latestIssueSecondaryCta.label}
            </a>
          ) : null}
        </div>
      </article>
    ) : (
      <article class="card home-surface" data-motion="gsap">
          <p class="muted">No issues have been published yet</p>
      </article>
    )}
  </section>

  <section class="section home-section" aria-labelledby="news-events-title">
    <div class="section-head home-section-head">
      <div>
        <p class="eyebrow">{newsEyebrow}</p>
        <h2 id="news-events-title">{newsHeading}</h2>
      </div>
    </div>

    <article class="card home-surface" data-motion="gsap">
      {newsItems.length > 0 ? (
        <ul class="home-about-bullets">
          {newsItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      ) : (
        <p class="muted">{newsEmptyStateText}</p>
      )}
    </article>
  </section>

  <section class="section home-section" aria-labelledby="browse-category-title">
    <div class="section-head home-section-head">
      <div>
        <p class="eyebrow">Browse by Category</p>
        <h2 id="browse-category-title">Explore Topic Areas</h2>
      </div>
    </div>

    <article class="card home-surface" data-motion="gsap">
      {categoryChips.length > 0 ? (
        <div class="home-category-chips" role="list" aria-label="Top categories">
          {categoryChips.map((category) => (
            <a class="home-category-chip" role="listitem" href={withBase(`/categories/${category.slug}/`)}>
              {category.name}
            </a>
          ))}
        </div>
      ) : (
        <>
          <p class="muted">Category pages will fill in as current-series papers are published</p>
          <div class="card-actions">
            <a class="btn btn-small btn-primary" href={withBase("/issues/archive/")}>Browse archive topics</a>
          </div>
        </>
      )}
    </article>
  </section>

  <section class="section home-section" aria-labelledby="about-bullets-title">
    <div class="section-head home-section-head">
      <div>
        <p class="eyebrow">About</p>
        <h2 id="about-bullets-title">What This Series Is</h2>
      </div>
      <a class="link-inline" href={withBase("/about/")}>Read full about</a>
    </div>

    <article class="card home-surface" data-motion="gsap">
      <ul class="home-about-bullets">
        <li>Open-access archive of UNLV Department of Economics working papers, organized by semester issue</li>
        <li>Working papers are posted for public reading; they are not peer-reviewed journal articles</li>
        <li>Each paper stays available on its own page with a downloadable PDF</li>
      </ul>
    </article>
  </section>
</BaseLayout>
