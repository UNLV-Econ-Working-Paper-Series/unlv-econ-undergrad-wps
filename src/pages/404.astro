---
import PageBanner from "../components/PageBanner.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/urls";
---

<BaseLayout title="Page Not Found | UNLV Undergraduate Economics Working Paper Series" bodyClass="page-404">
  <PageBanner
    title="Page Not Found"
    lead="The page you requested is not available on the UNLV Undergraduate Economics Working Paper Series site."
  />

  <section class="content-section">
    <article class="accent-card empty-state-card">
      <h2>Try one of these sections instead</h2>
      <p class="muted">
        You may have followed an outdated link, or the page may not be published yet.
      </p>
      <div class="card-actions">
        <a class="btn btn-small" href={withBase("/")}>Home</a>
        <a class="btn btn-small btn-primary" href={withBase("/issues/")}>Browse issues</a>
        <a class="btn btn-small" href={withBase("/issues/archive/")}>Browse archive</a>
      </div>
    </article>
  </section>
</BaseLayout>
