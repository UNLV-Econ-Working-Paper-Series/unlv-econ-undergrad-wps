---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/urls";

const target = withBase("/issues/");
---

<BaseLayout title="Redirecting to Issues">
  <article class="card">
    <p>This legacy pagination URL has moved.</p>
    <p><a href={target}>Continue to Issues</a></p>
  </article>
  <script is:inline define:vars={{ target }}>
    window.location.replace(target);
  </script>
</BaseLayout>
