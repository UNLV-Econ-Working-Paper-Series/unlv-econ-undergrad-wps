---
import PageBanner from "../../components/PageBanner.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cleanPaperTitle, getIssueGroups, type IssueGroup, paperHref } from "../../lib/papers";
import { publicAssetExists } from "../../lib/publicAssets";
import { withBase } from "../../lib/urls";

export async function getStaticPaths() {
  const issues = await getIssueGroups();
  return issues.map((issue) => ({ params: { issue: issue.slug }, props: { issue } }));
}

const { issue } = Astro.props as { issue: IssueGroup };
const issueSlug = issue.slug;
const papers = issue.papers;
const issueLabel = issue.label;
const issueZipPath = `/assets/issues/${issueSlug}/${issueSlug}-pdfs.zip`;
const issueZipHref = withBase(issueZipPath);
const issueZipAvailable = publicAssetExists(issueZipPath);
---

<BaseLayout title={`${issueLabel} | Issues`} bodyClass="section-issues page-issue-detail">
  <div class="issue-layout">
    <PageBanner
      kicker="Issue"
      title={issueLabel}
      subtitle={papers.length > 0 ? `Browse working papers published in ${issueLabel}` : "Papers for this issue will be posted soon."}
    />

    <section class="content-section issue-content">
      <div class="page-intro-actions">
        <a class="btn btn-small" href={withBase("/issues/")}>Back to issues</a>

        {papers.length > 0 && issueZipAvailable ? (
          <a class="btn btn-small btn-primary" href={issueZipHref}>
            Download ZIP (PDFs)
          </a>
        ) : null}
      </div>

      {papers.length > 0 && issueZipAvailable ? (
        <p class="muted small" style="margin: 0.6rem 0 0;">
          This download packages all PDFs from <strong>{issueLabel}</strong> into a single ZIP file.
        </p>
      ) : null}

      {papers.length === 0 ? (
        <article class="accent-card empty-state-card">
          <h2>Coming soon</h2>
          <p class="muted">Papers for this issue will be posted soon.</p>
          <div class="card-actions">
            <a class="btn btn-small" href={withBase("/issues/")}>Back to issues</a>
            <a class="btn btn-small btn-primary" href={withBase("/issues/archive/")}>Browse archive</a>
          </div>
        </article>
      ) : (
        <>
          <h2 class="section-title">Papers in This Issue</h2>
          <div class="card-grid issue-paper-grid">
            {papers.map((paper) => (
              <article class="card paper-card accent-card">
                <div class="paper-meta">
                  {paper.data.published_at ? <span class="pill">{paper.data.published_at}</span> : null}
                  <span class="pill light">{issueLabel}</span>
                </div>
                <h3><a href={paperHref(paper)}>{cleanPaperTitle(paper.data.title)}</a></h3>
                <p class="muted small">By {paper.data.authors.join(", ")}</p>
                <p class="muted small">Category: {paper.data.category}</p>
                <p class="muted">{paper.data.abstract.slice(0, 240)}{paper.data.abstract.length > 240 ? "..." : ""}</p>
                <div class="card-actions">
                  <a class="btn btn-small" href={paperHref(paper)}>Read abstract</a>
                  <a class="btn btn-small btn-primary" href={withBase(paper.data.pdf)}>Download PDF</a>
                </div>
              </article>
            ))}
          </div>
        </>
      )}
    </section>
  </div></BaseLayout>
