---
import PageBanner from "../../../components/PageBanner.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getArchiveIssueGroups, type ArchiveIssueGroup } from "../../../lib/archive";
import { withBase } from "../../../lib/urls";

export async function getStaticPaths() {
  const issues = getArchiveIssueGroups();
  return issues.map((issue) => ({ params: { issue: issue.slug }, props: { issue } }));
}

const { issue } = Astro.props as { issue: ArchiveIssueGroup };
const availablePapers = issue.papers.filter((paper) => paper.fileAvailable);
---

<BaseLayout title={`${issue.label} | Archive`} bodyClass="section-issues page-archive-issue">
  <PageBanner
    kicker="Archive Issue"
    title={issue.label}
    subtitle={`Archive issue with ${issue.papers.length} working paper(s) and ${issue.categories.length} topic categories.`}
  />

  <section class="content-section">
    <article class="issue-archive-card card">
      <header class="issue-archive-head">
        <h2>Issue Summary</h2>
        <p class="issue-card-meta">
          {issue.papers.length} papers • {issue.categories.length} categories
        </p>
      </header>

      <div class="issue-topic-chips" aria-label={`Categories in ${issue.label}`}>
        {issue.categories.map((category) => (
          <span class="issue-topic-chip">{category}</span>
        ))}
      </div>

      <div class="issue-card-actions">
        <a class="btn btn-small" href={withBase("/issues/archive/")}>Back to archive</a>
        {availablePapers.length > 0 ? (
          <button
            type="button"
            class="btn btn-small btn-outline"
            data-download-all
            data-urls={availablePapers.map((paper) => withBase(paper.file)).join("|")}
          >
            Download PDFs
          </button>
        ) : null}
      </div>

      {availablePapers.length === 0 ? (
        <p class="muted small">PDF files for this archive issue are not online yet.</p>
      ) : null}
    </article>

    <div class="archive-paper-list archive-paper-list--issue" aria-label="Papers in this archive issue">
      {issue.papers.map((paper) => (
        <article class="archive-paper-item card">
          <h3>{paper.title}</h3>
          <p class="muted small">Authors: {paper.authors || "Not listed"}</p>
          <div class="issue-card-actions">
            {paper.fileAvailable ? (
              <a class="btn btn-small btn-primary" href={withBase(paper.file)}>Download PDF</a>
            ) : (
              <p class="muted small">PDF not currently available online.</p>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <script is:inline>
    const button = document.querySelector("[data-download-all]");

    button?.addEventListener("click", () => {
      const urls = (button.dataset.urls || "").split("|").filter(Boolean);
      if (urls.length === 0) {
        return;
      }

      urls.forEach((url, index) => {
        window.setTimeout(() => {
          const link = document.createElement("a");
          link.href = url;
          link.download = "";
          link.rel = "noopener noreferrer";
          document.body.append(link);
          link.click();
          link.remove();
        }, index * 180);
      });
    });
  </script>
</BaseLayout>
