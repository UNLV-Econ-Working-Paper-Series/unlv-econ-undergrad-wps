---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cleanPaperTitle, getCategoryGroups, getIssueLabelForPaper, paperHref } from "../../lib/papers";
import { withBase } from "../../lib/urls";

export async function getStaticPaths() {
  const categories = await getCategoryGroups();
  return categories.map((category) => ({ params: { category: category.slug } }));
}

const categorySlug = Astro.params.category ?? "";
const categories = await getCategoryGroups();
const category = categories.find((item) => item.slug === categorySlug);
const papers = category?.papers ?? [];
const categoryName = category?.name ?? categorySlug;
---

<BaseLayout title={`${categoryName} | Categories`} bodyClass="section-categories page-category-detail">
  <section class="page-intro page-intro--standard">
    <p class="eyebrow">Category</p>
    <h1>{categoryName}</h1>
    <p class="page-subtitle">Working papers tagged for {categoryName}.</p>
    <div class="page-intro-actions">
      <a class="btn btn-small" href={withBase("/categories/")}>Back to categories</a>
    </div>
  </section>

  <section class="content-section">
    {papers.length === 0 ? (
      <article class="accent-card empty-state-card">
        <p class="muted">No papers yet in this category.</p>
      </article>
    ) : (
      <div class="card-grid">
        {papers.map((paper) => (
          <article class="card paper-card accent-card">
            <div class="paper-meta">
              {paper.data.published_at ? <span class="pill">{paper.data.published_at}</span> : null}
              <span class="pill light">{getIssueLabelForPaper(paper)}</span>
            </div>
            <h3><a href={paperHref(paper)}>{cleanPaperTitle(paper.data.title)}</a></h3>
            <p class="muted small">By {paper.data.authors.join(", ")}</p>
            <p class="muted">{paper.data.abstract.slice(0, 220)}{paper.data.abstract.length > 220 ? "..." : ""}</p>
            <div class="card-actions">
              <a class="btn btn-small" href={paperHref(paper)}>Read abstract</a>
              <a class="btn btn-small btn-primary" href={withBase(paper.data.pdf)}>Download PDF</a>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
