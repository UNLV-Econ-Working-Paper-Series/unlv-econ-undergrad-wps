---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/urls";

const target = withBase("/categories/industrial-organization-io-and-strategy/");
---

<BaseLayout title="Redirecting Category">
  <article class="card">
    <p>This category moved.</p>
    <p><a href={target}>Continue to Industrial Organization (IO) & Strategy</a></p>
  </article>
  <script is:inline define:vars={{ target }}>
    window.location.replace(target);
  </script>
</BaseLayout>
