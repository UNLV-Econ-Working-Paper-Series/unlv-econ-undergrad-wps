---
import { getCollection, render, type CollectionEntry } from "astro:content";
import PageBanner from "../../components/PageBanner.astro";
import ProfileLinks from "../../components/ProfileLinks.astro";
import { PUBLIC_PROFILES } from "../../data/public-profiles";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/urls";

export async function getStaticPaths() {
  const assistants = await getCollection("graduateAssistants");
  return assistants.map((assistant) => ({
    params: { slug: assistant.slug },
    props: { assistant },
  }));
}

const { assistant } = Astro.props as { assistant: CollectionEntry<"graduateAssistants"> };
const { Content } = await render(assistant);
const assistantProfile = PUBLIC_PROFILES.find(
  (profile) => profile.profileHref === `/graduate-assistants/${assistant.slug}/`
);
---

<BaseLayout title={`${assistant.data.name} | Graduate Assistants`} bodyClass="section-about page-profile">
  <PageBanner title={assistant.data.name} lead={`${assistant.data.role} (${assistant.data.term})`} />

  <section class="content-section profile-shell">
    {assistant.data.headshot ? (
      <img
        class="profile-thumb"
        src={withBase(assistant.data.headshot)}
        alt={assistant.data.name}
        loading="lazy"
        title={assistantProfile?.photoSource}
      />
    ) : null}

    <article class="profile-bio">
      <Content />
    </article>

    <ProfileLinks links={assistantProfile?.links} className="profile-page-links" />

    <p class="profile-back-link">
      <a href={withBase("/graduate-assistants/")}>← Back to Graduate Assistants</a>
    </p>
  </section>
</BaseLayout>
