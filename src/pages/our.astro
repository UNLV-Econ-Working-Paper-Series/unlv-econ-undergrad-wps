---
import PageBanner from "../components/PageBanner.astro";
import TableOfContents from "../components/TableOfContents.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/urls";
import { OUR_LINKS, SPECTRA_LINKS, SPECTRA_PUBLISHES, SPECTRA_REVIEW, SYMPOSIA_POINTS } from "../config/our";

const symposiaPrimary = OUR_LINKS.find((link) => link.kind === "primary") ?? null;
const symposiaSecondary = OUR_LINKS.filter((link) => link.kind === "secondary");
const spectraPrimary = SPECTRA_LINKS.find((link) => link.kind === "primary") ?? null;

const pathwayCards = [
  {
    kicker: "Archive",
    title: "ECON 495 Journal (This Site)",
    summary: "Your paper gets a stable page, metadata, and PDF for citation and discovery.",
    href: withBase("/papers/"),
    label: "Browse archive",
    external: false,
  },
  {
    kicker: "Present",
    title: "OUR Symposia",
    summary: "Share your findings publicly and get feedback that improves your manuscript.",
    href: symposiaPrimary?.href || "https://www.unlv.edu/our/research-symposia",
    label: "Visit Research Symposia",
    external: true,
  },
  {
    kicker: "Publish",
    title: "Spectra Journal",
    summary: "Strong projects can become mentored, peer-reviewed undergraduate publications.",
    href: spectraPrimary?.href || "https://oasis.library.unlv.edu/spectra/",
    label: "Visit Spectra Journal",
    external: true,
  },
];

const tocItems = [
  { id: "our-connection-title", label: "Overview" },
  { id: "our-symposia-title", label: "Research Symposia" },
  { id: "our-spectra-title", label: "Spectra Journal" },
];
---

<BaseLayout title="Undergraduate Research | UNLV ECON 495 Journal" bodyClass="section-our page-our page-our-modern">
  <PageBanner
    title="Undergraduate Research Pathway"
    lead="How ECON 495 projects can be presented and developed into publishable scholarship at UNLV."
    note="External links: Office of Undergraduate Research (OUR) and Spectra. The Proceedings remains the course archive."
  />

  <div class="page-with-toc">
    <aside class="page-with-toc__toc">
      <TableOfContents items={tocItems} />
    </aside>

    <div class="page-with-toc__main">
      <div class="our-modern-page">
    <section class="content-section our-connection-section" aria-labelledby="our-connection-title">
      <header class="our-section-head our-section-head--linear">
        <h2 id="our-connection-title">Beyond ECON 495: Present &amp; Publish</h2>
        <p class="our-connection-intro">
          ECON 495 projects often follow a clear pathway: <strong>archive - present - revise - publish</strong>.
        </p>
      </header>

      <div class="our-path-grid" role="list" aria-label="Research pathway overview">
        {pathwayCards.map((card) => (
          <article class="our-surface our-path-card" role="listitem">
            <p class="our-path-kicker">{card.kicker}</p>
            <h3>{card.title}</h3>
            <p>{card.summary}</p>
            {card.external ? (
              <a class="our-path-link" href={card.href} target="_blank" rel="noopener noreferrer">{card.label} →</a>
            ) : (
              <a class="our-path-link" href={card.href}>{card.label} →</a>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="content-section our-section our-section--present" aria-labelledby="our-symposia-title">
      <header class="our-section-head our-section-head--linear">
        <h2 id="our-symposia-title">OUR Undergraduate Research Symposia</h2>
        <p>
          The Office of Undergraduate Research (OUR) hosts public forums where students present capstone and independent
          projects and receive constructive feedback.
        </p>
      </header>

      <div class="our-layout-two-col">
        <article class="our-surface our-main-copy">
          <ul class="our-list">
            {SYMPOSIA_POINTS.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </article>

        <aside class="our-surface our-links-card" aria-label="Symposia quick links">
          <h3>Quick Links</h3>
          {symposiaPrimary ? (
            <a class="btn btn-small btn-primary" href={symposiaPrimary.href} target="_blank" rel="noopener noreferrer">
              {symposiaPrimary.label}
            </a>
          ) : null}

          <ul class="our-text-links">
            {symposiaSecondary.map((link) => (
              <li>
                <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section class="content-section our-bridge" aria-label="Symposia to publication transition">
      <article class="our-surface our-bridge-card">
        <p>
          Presenting at the Undergraduate Research Symposia often becomes the bridge from class project to polished manuscript
          for journal submission.
        </p>
      </article>
    </section>

    <section class="content-section our-section our-section--publish" aria-labelledby="our-spectra-title">
      <header class="our-section-head our-section-head--linear">
        <h2 id="our-spectra-title">Spectra Undergraduate Research Journal</h2>
        <p>
          Spectra is UNLV&apos;s peer-reviewed, open-access undergraduate journal pathway for mentored research.
        </p>
      </header>

      <div class="our-mini-grid" aria-label="Spectra publication details">
        <article class="our-surface our-mini-card">
          <h3>What Spectra publishes</h3>
          <ul class="our-list our-list--compact">
            {SPECTRA_PUBLISHES.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>

        <article class="our-surface our-mini-card">
          <h3>How review works</h3>
          <ul class="our-list our-list--compact">
            {SPECTRA_REVIEW.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      </div>

      <div class="our-section-actions">
        {spectraPrimary ? (
          <a class="btn btn-small btn-primary" href={spectraPrimary.href} target="_blank" rel="noopener noreferrer">
            {spectraPrimary.label}
          </a>
        ) : null}
      </div>

      <details class="our-accordion">
        <summary>Read more: submission expectations and support resources</summary>
        <div class="our-accordion-body">
          <p>
            Strong ECON 495 projects can continue toward publication with revision support, mentor feedback, and journal-style
            preparation through UNLV undergraduate research resources.
          </p>
          <p>
            Use the proceedings archive, symposium feedback, and faculty guidance as a practical progression from course research
            to public scholarship.
          </p>
        </div>
      </details>
    </section>
      </div>
    </div>

  </div>
</BaseLayout>
