---
import PageBanner from "../components/PageBanner.astro";
import TableOfContents from "../components/TableOfContents.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/urls";
import { OUR_LINKS, SPECTRA_LINKS, SPECTRA_PUBLISHES, SPECTRA_REVIEW, SYMPOSIA_POINTS } from "../config/our";

const symposiaPrimary = OUR_LINKS.find((link) => link.kind === "primary") ?? null;
const symposiaSecondary = OUR_LINKS.filter((link) => link.kind === "secondary");
const spectraPrimary = SPECTRA_LINKS.find((link) => link.kind === "primary") ?? null;

const pathwayCards = [
  {
    kicker: "Archive",
    title: "UNLV Undergraduate Economics Working Paper Series (This Site)",
    summary: "Post a working paper with its own page, abstract, and PDF.",
    href: withBase("/papers/"),
    label: "Browse archive",
    external: false,
  },
  {
    kicker: "Present",
    title: "OUR Symposia",
    summary: "Present your work publicly and get comments you can use in revision.",
    href: symposiaPrimary?.href || "https://www.unlv.edu/our/research-symposia",
    label: "Visit Research Symposia",
    external: true,
  },
  {
    kicker: "Publish",
    title: "Spectra Journal",
    summary: "Some projects may later be submitted to Spectra.",
    href: spectraPrimary?.href || "https://oasis.library.unlv.edu/spectra/",
    label: "Visit Spectra Journal",
    external: true,
  },
];

const tocItems = [
  { id: "our-connection-title", label: "Overview" },
  { id: "our-symposia-title", label: "Research Symposia" },
  { id: "our-spectra-title", label: "Spectra Journal" },
];
---

<BaseLayout title="Research Pathway | UNLV Undergraduate Economics Working Paper Series" bodyClass="section-our page-our page-our-modern">
  <PageBanner
    title="Economics Research Pathway"
    lead="How Economics Department papers can move from a working paper to a campus presentation or journal submission."
  />

  <div class="page-with-toc">
    <aside class="page-with-toc__toc">
      <TableOfContents items={tocItems} />
    </aside>

    <div class="page-with-toc__main">
      <div class="our-modern-page">
    <section class="content-section our-connection-section" aria-labelledby="our-connection-title">
      <header class="our-section-head our-section-head--linear">
        <h2 id="our-connection-title">From Archive to Present &amp; Publish</h2>
        <p class="our-connection-intro">
          Many student papers begin as class or independent research projects. They may be posted here first, presented at a
          symposium, and later revised for journal submission.
        </p>
      </header>

      <div class="our-path-grid" role="list" aria-label="Research pathway overview">
        {pathwayCards.map((card) => (
          <article class="our-surface our-path-card" data-motion="gsap" role="listitem">
            <p class="our-path-kicker">{card.kicker}</p>
            <h3>{card.title}</h3>
            <p>{card.summary}</p>
            {card.external ? (
              <a class="our-path-link" href={card.href} target="_blank" rel="noopener noreferrer">{card.label} →</a>
            ) : (
              <a class="our-path-link" href={card.href}>{card.label} →</a>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="content-section our-section our-section--present" aria-labelledby="our-symposia-title">
      <header class="our-section-head our-section-head--linear">
        <h2 id="our-symposia-title">OUR Undergraduate Research Symposia</h2>
        <p>
          The Office of Undergraduate Research (OUR) hosts public forums where undergraduate researchers present independent
          and course-based projects and receive constructive feedback.
        </p>
      </header>

      <div class="our-layout-two-col">
        <article class="our-surface our-main-copy" data-motion="gsap">
          <ul class="our-list">
            {SYMPOSIA_POINTS.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </article>

        <aside class="our-surface our-links-card" data-motion="gsap" aria-label="Symposia quick links">
          <h3>Quick Links</h3>
          {symposiaPrimary ? (
            <a class="btn btn-small btn-primary" href={symposiaPrimary.href} target="_blank" rel="noopener noreferrer">
              {symposiaPrimary.label}
            </a>
          ) : null}

          <ul class="our-text-links">
            {symposiaSecondary.map((link) => (
              <li>
                <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section class="content-section our-bridge" aria-label="Symposia to publication transition">
      <article class="our-surface our-bridge-card" data-motion="gsap">
        <p>
          For many students, the symposium is the first chance to present a paper outside the classroom and see what needs revision.
        </p>
      </article>
    </section>

    <section class="content-section our-section our-section--publish" aria-labelledby="our-spectra-title">
      <header class="our-section-head our-section-head--linear">
        <h2 id="our-spectra-title">Spectra Undergraduate Research Journal</h2>
        <p>
          Spectra is UNLV&apos;s undergraduate research journal. Economics papers that are revised and ready for review may be submitted there.
        </p>
      </header>

      <div class="our-mini-grid" aria-label="Spectra publication details">
        <article class="our-surface our-mini-card" data-motion="gsap">
          <h3>What Spectra publishes</h3>
          <ul class="our-list our-list--compact">
            {SPECTRA_PUBLISHES.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>

        <article class="our-surface our-mini-card" data-motion="gsap">
          <h3>How review works</h3>
          <ul class="our-list our-list--compact">
            {SPECTRA_REVIEW.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      </div>

      <div class="our-section-actions">
        {spectraPrimary ? (
          <a class="btn btn-small btn-primary" href={spectraPrimary.href} target="_blank" rel="noopener noreferrer">
            {spectraPrimary.label}
          </a>
        ) : null}
      </div>

      <details class="our-accordion">
        <summary>Read more: preparing a paper for submission</summary>
        <div class="our-accordion-body">
          <p>
            A paper usually gets stronger after revision, faculty feedback, and public presentation.
          </p>
          <p>
            Use this site to post a draft, use the symposium to test it in front of an audience, and use faculty guidance if you decide
            to submit the paper elsewhere.
          </p>
        </div>
      </details>
    </section>
      </div>
    </div>

  </div>
</BaseLayout>
