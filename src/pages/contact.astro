---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | UNLV ECON 495 Journal" bodyClass="section-contact page-contact">
  <section class="page-intro page-intro--band full-bleed">
    <div class="page-intro-title">
      <h1>Contact</h1>
    </div>
    <div class="page-intro-subtitle">
      <p>Reach the journal team and department office.</p>
    </div>
  </section>

  <section class="content-section contact-shell">
    <article class="contact-office contact-office--primary">
      <h2>Department of Economics</h2>
      <p class="muted small">
        Mailing Address:<br />
        Department of Economics<br />
        University of Nevada, Las Vegas<br />
        Mail Stop: 6005<br />
        4505 S. Maryland Pkwy.<br />
        Las Vegas, NV 89154
      </p>
      <p class="muted small">
        Phone: 702-895-3776<br />
        Campus Location: Frank and Estella Beam Hall (BEH), Room 508
      </p>
    </article>

    <details class="more-details">
      <summary class="more-details__summary">More Details</summary>
      <div class="more-details__content">
        <section class="contact-directory">
          <article class="contact-profile">
            <h2>Professor Djeto Assane, Ph.D.</h2>
            <p class="contact-role">ECON 495 Instructor</p>
            <ul class="contact-link-list">
              <li><a href="mailto:djeto.assane@unlv.edu">Email: djeto.assane@unlv.edu</a></li>
              <li>
                <a href="https://scholar.google.com/citations?user=VJYYWTIAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">
                  Google Scholar Profile
                </a>
              </li>
            </ul>
          </article>

          <article class="contact-profile">
            <h2>Mark Jayson Farol, M.A.</h2>
            <p class="contact-role">Journal Organizer</p>
            <ul class="contact-link-list">
              <li><a href="mailto:series-team@unlv.edu">Email: series-team@unlv.edu</a></li>
              <li>
                <a href="https://scholar.google.com/citations?hl=en&user=vdr24hsAAAAJ" target="_blank" rel="noopener noreferrer">
                  Google Scholar Profile
                </a>
              </li>
              <li>
                <a href="https://www.linkedin.com/in/markjaysonfarol" target="_blank" rel="noopener noreferrer">LinkedIn</a>
              </li>
            </ul>
          </article>
        </section>
      </div>
    </details>
  </section>
</BaseLayout>
