---
import ContactCard from "../components/ContactCard.astro";
import PageBanner from "../components/PageBanner.astro";
import { CONTACT } from "../config/contact";
import BaseLayout from "../layouts/BaseLayout.astro";

const journalActions = [
  { label: "Email Journal Team", href: `mailto:${CONTACT.journal.email}`, primary: true },
  { label: "Common Requests", href: "#requests" },
];

const deptActions = [
  { label: "Call Office", href: `tel:${CONTACT.dept.phone}`, primary: true },
  { label: "Get Directions", href: CONTACT.dept.directionsUrl, external: true },
];

const commonRequests = [
  { label: "Broken link", subject: "Report a broken link" },
  { label: "Author update", subject: "Author update request" },
  { label: "Correction / updated PDF", subject: "Correction or updated PDF" },
  { label: "Permissions / reuse", subject: "Permissions or reuse" },
  { label: "Takedown", subject: "Takedown request" },
];
---

<BaseLayout title="Contact | UNLV ECON 495 Journal" bodyClass="section-contact page-contact page-contact-modern">
  <PageBanner title="Contact" lead="Reach the journal team or the Department of Economics office." />

  <section class="content-section contact-modern-shell">
    <h1 class="contact-sr-only">Contact</h1>

    <section class="contact-grid" aria-labelledby="contact-routing-title">
      <h2 id="contact-routing-title" class="contact-grid-heading">Who are you trying to reach?</h2>

      <ContactCard title={CONTACT.journal.title} desc={CONTACT.journal.desc} actions={journalActions}>
        <p class="contact-line">
          <strong>Email:</strong>
          <a href={`mailto:${CONTACT.journal.email}`}>{CONTACT.journal.email}</a>
        </p>
        <p class="contact-hint">
          Use this for corrections, permissions, takedown requests, author updates, and site issues.
        </p>
      </ContactCard>

      <ContactCard title={CONTACT.dept.title} desc={CONTACT.dept.desc} actions={deptActions}>
        <p class="contact-line">
          <strong>Phone:</strong>
          <a href={`tel:${CONTACT.dept.phone}`}>{CONTACT.dept.phone}</a>
        </p>
        <p class="contact-line"><strong>Location:</strong> {CONTACT.dept.locationLine}</p>
        <address class="contact-address">
          {CONTACT.dept.addressLines.map((line) => (
            <div>{line}</div>
          ))}
        </address>
      </ContactCard>
    </section>

    <section id="requests" class="contact-requests" aria-labelledby="requests-title">
      <h2 id="requests-title">Common Requests</h2>
      <div class="contact-chip-list" role="list" aria-label="Common journal support requests">
        {commonRequests.map((request) => (
          <a
            role="listitem"
            class="contact-chip"
            href={`mailto:${CONTACT.journal.email}?subject=${encodeURIComponent(request.subject)}`}
          >
            {request.label}
          </a>
        ))}
      </div>
      <p class="contact-note">
        For paper-specific issues, include the paper title and paper URL. For reuse requests, include what content you want to
        reuse and where it will be used.
      </p>
    </section>

    <section class="contact-map" aria-labelledby="directions-title">
      <h2 id="directions-title">Directions</h2>
      <p>
        <a href={CONTACT.dept.directionsUrl} target="_blank" rel="noopener noreferrer">Open in Google Maps →</a>
      </p>
    </section>
  </section>
</BaseLayout>
