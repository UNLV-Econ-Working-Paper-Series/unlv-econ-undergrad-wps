---
import ContactCard from "../components/ContactCard.astro";
import PageBanner from "../components/PageBanner.astro";
import { CONTACT_PAGE_CONTENT } from "../data/contact-content";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | UNLV Undergraduate Economics Working Paper Series" bodyClass="section-contact page-contact page-contact-modern">
  <PageBanner title={CONTACT_PAGE_CONTENT.banner.title} lead={CONTACT_PAGE_CONTENT.banner.lead} />

  <section class="content-section contact-modern-shell">
    <h1 class="contact-sr-only">Contact</h1>

    <section class="contact-grid" aria-labelledby="contact-routing-title">
      <h2 id="contact-routing-title" class="contact-grid-heading">{CONTACT_PAGE_CONTENT.routingTitle}</h2>

      <ContactCard
        title={CONTACT_PAGE_CONTENT.contact.series.title}
        desc={CONTACT_PAGE_CONTENT.contact.series.desc}
        actions={CONTACT_PAGE_CONTENT.contact.series.actions}
      >
        <p class="contact-line">
          <strong>Email:</strong>
          <a href={`mailto:${CONTACT_PAGE_CONTENT.contact.series.email}`}>{CONTACT_PAGE_CONTENT.contact.series.email}</a>
        </p>
        <p class="contact-hint">
          {CONTACT_PAGE_CONTENT.contact.series.hint}
        </p>
      </ContactCard>

      <ContactCard
        title={CONTACT_PAGE_CONTENT.contact.dept.title}
        desc={CONTACT_PAGE_CONTENT.contact.dept.desc}
        actions={CONTACT_PAGE_CONTENT.contact.dept.actions}
      >
        <p class="contact-line">
          <strong>Phone:</strong>
          <a href={`tel:${CONTACT_PAGE_CONTENT.contact.dept.phone}`}>{CONTACT_PAGE_CONTENT.contact.dept.phone}</a>
        </p>
        <p class="contact-line"><strong>Location:</strong> {CONTACT_PAGE_CONTENT.contact.dept.locationLine}</p>
        <address class="contact-address">
          {CONTACT_PAGE_CONTENT.contact.dept.addressLines.map((line) => (
            <div>{line}</div>
          ))}
        </address>
      </ContactCard>
    </section>

    <section id="requests" class="contact-requests" aria-labelledby="requests-title">
      <h2 id="requests-title">{CONTACT_PAGE_CONTENT.requests.title}</h2>
      <div class="contact-chip-list" role="list" aria-label="Common series support requests">
        {CONTACT_PAGE_CONTENT.requests.items.map((request) => (
          <a
            role="listitem"
            class="contact-chip"
            href={`mailto:${CONTACT_PAGE_CONTENT.contact.series.email}?subject=${encodeURIComponent(request.subject)}`}
          >
            {request.label}
          </a>
        ))}
      </div>
      <p class="contact-note">{CONTACT_PAGE_CONTENT.requests.note}</p>
    </section>

    <section class="contact-map" aria-labelledby="directions-title">
      <h2 id="directions-title">{CONTACT_PAGE_CONTENT.directions.title}</h2>
      <p>
        <a
          href={CONTACT_PAGE_CONTENT.contact.dept.directionsUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          {CONTACT_PAGE_CONTENT.directions.linkLabel}
        </a>
      </p>
    </section>
  </section>
</BaseLayout>
